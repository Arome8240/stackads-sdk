{
  "name": "stackads-sdk",
  "version": "0.1.1",
  "description": "TypeScript SDK for interacting with StackAds contracts on the Stacks blockchain",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:utils": "vitest run tests/utils.test.ts",
    "test:ad": "vitest run tests/ad.test.ts",
    "test:constants": "vitest run tests/constants.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "stacks",
    "blockchain",
    "bitcoin",
    "ads",
    "advertising",
    "stx",
    "sdk"
  ],
  "author": "Dev Arome",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Arome8240/stackads-sdk"
  },
   "bugs": {
    "url": "https://github.com/Arome8240/stackads-sdk/issues"
  },
  "homepage": "https://github.com/Arome8240/stackads-sdk#readme",
  "dependencies": {
    "@stacks/transactions": "^6.17.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
